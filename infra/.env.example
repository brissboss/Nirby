# =============================================================================
# Exemple pour le docker-compose LOCAL (infra/docker-compose.yaml)
# Copier : cp .env.example .env
# Compose charge automatiquement infra/.env depuis ce répertoire.
#
# Staging / production : pas ce fichier — secrets GitHub (DB_PASSWORD,
# DB_APP_PASSWORD, etc.) et infra/staging|prod/docker-compose.yaml.
# =============================================================================

# --- API : requis ou valeurs par défaut dans le compose ----------------------
# Générer avec : openssl rand -base64 64
JWT_SECRET=

# Resend (https://resend.com), préfixe re_
# Sans clé réelle : le compose utilise un placeholder (pas d’e-mails).
RESEND_API_KEY=

# --- API : optionnel -----------------------------------------------------------
# Google Places (préfixe AIza)
GOOGLE_PLACES_API_KEY=

# Front (CORS, liens dans les e-mails)
FRONTEND_URL=http://localhost:3000

# S3 / Minio (aligné sur le compose local avec Minio)
S3_BUCKET=nirby-uploads-dev
S3_REGION=eu-west-3
S3_ACCESS_KEY_ID=nirbyadmin
S3_SECRET_ACCESS_KEY=nirbyadmin123
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_URL=http://localhost:9000/nirby-uploads-dev

# IDs modèles Resend (optionnel ; le code a des valeurs par défaut)
# EMAIL_VERIFICATION_TEMPLATE_ID_EN=
# EMAIL_VERIFICATION_TEMPLATE_ID_FR=
# EMAIL_PASSWORD_RESET_TEMPLATE_ID_EN=
# EMAIL_PASSWORD_RESET_TEMPLATE_ID_FR=
# L’API utilise aussi (variables optionnelles selon le code) :
# EMAIL_ACCOUNT_DELETED_TEMPLATE_ID_EN=
# EMAIL_ACCOUNT_DELETED_TEMPLATE_ID_FR=
# EMAIL_COLLABORATOR_INVITE_TEMPLATE_ID_EN=
# EMAIL_COLLABORATOR_INVITE_TEMPLATE_ID_FR=

# --- Build du front (optionnel) -----------------------------------------------
# NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
