# Database (Prisma 7)
# Runtime API — PrismaPg (src/db.ts)
DATABASE_URL="postgresql://nirby:nirby@localhost:5432/nirby"

# CLI Prisma (migrate, etc.) — prisma.config.ts → datasource.url
# Optionnel en dev : si absent, DATABASE_URL est utilisée.
# Staging/prod : URL « migration » (utilisateur nirby), distincte du runtime (nirby_app).
# MIGRATE_DATABASE_URL="postgresql://nirby:nirby@localhost:5432/nirby"

# Redis
REDIS_URL="redis://localhost:6379"

# Server
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# AUTH
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL=7
## Generate with 'openssl rand -base64 64'
JWT_SECRET=""
RESEND_API_KEY=

# FRONT
FRONTEND_URL=

# RESEND
EMAIL_VERIFICATION_TEMPLATE_ID_EN=
EMAIL_VERIFICATION_TEMPLATE_ID_FR=
EMAIL_PASSWORD_RESET_TEMPLATE_ID_EN=
EMAIL_PASSWORD_RESET_TEMPLATE_ID_FR=
EMAIL_ACCOUNT_DELETED_TEMPLATE_ID_EN=
EMAIL_ACCOUNT_DELETED_TEMPLATE_ID_FR=
EMAIL_COLLABORATOR_INVITE_TEMPLATE_ID_EN=
EMAIL_COLLABORATOR_INVITE_TEMPLATE_ID_FR=

# GOOGLE
GOOGLE_PLACES_API_KEY=

# AWS S3
S3_BUCKET=nirby-uploads-dev
S3_REGION=eu-west-3
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_URL=http://localhost:9000/nirby-uploads-dev
